{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build firmware",
      "type": "shell",
      "command": "make -j$(nproc)",
      "options": {
        "cwd": "${workspaceFolder}/firmware/build"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean rebuild firmware",
      "type": "shell",
      "command": "make clean && make -j$(nproc)",
      "options": {
        "cwd": "${workspaceFolder}/firmware/build"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Flash firmware (OpenOCD)",
      "type": "shell",
      "command": "openocd -f interface/stlink.cfg -f target/stm32f1x.cfg -c \"program build/firmware.elf verify reset exit\"",
      "options": {
        "cwd": "${workspaceFolder}/firmware"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
